// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// Ini adalah representasi tabel di database kamu
model ProgressLog {
  id             String   @id @default(uuid())
  userId         String   @default("guest-user")
  tanggal        DateTime @default(now())
  
  startSurah     Int
  startAyah      Int
  endSurah       Int
  endAyah        Int
  
  // BERUBAH: Dari totalAyahsRead (Int) menjadi totalPagesRead (Float)
  totalPagesRead Float    
  
  rawTranscript  String?  @db.Text
  createdAt      DateTime @default(now())
}
